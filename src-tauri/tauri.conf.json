{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DubMux",
  "version": "0.1.0",
  "identifier": "dev.optimax.dubmux",
  "build": {
    "beforeDevCommand": "yarn dev",
    "beforeBuildCommand": "yarn build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DubMux",
        "width": 1320,
        "height": 880,
        "minWidth": 1100,
        "minHeight": 760,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "windows": {
      "digestAlgorithm": "sha256"
    }
  }
}
